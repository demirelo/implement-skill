{
  "name": "python-pytest",
  "detect": ["pyproject.toml", "setup.py", "conftest.py"],
  "test_layout": "tests/test_*.py with `def test_*` functions; plain asserts",
  "test_cmd": "pytest -q --tb=no -rf",
  "test_one": "pytest {path} -q --tb=no -rf",
  "timeout": 600,
  "lint_cmd": "ruff check .",
  "type_cmd": "mypy ."
}
